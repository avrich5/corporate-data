# .env.example — copy to .env and fill in values
# Never commit .env to version control

# ─── LLM Providers ────────────────────────────────────────────
# At least one key required. Both enables provider competition mode.
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Provider strategy for Stage 02:
#   single_anthropic  — use only Claude (default)
#   single_openai     — use only GPT-4o
#   compete           — run both, compare, pick higher confidence
LLM_PROVIDER_STRATEGY=compete

# Model overrides (defaults shown)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# ─── Pipeline parameters (defaults in config.py) ──────────────
# CONFIDENCE_RESOLVED_THRESHOLD=0.85
# CONFIDENCE_CONFIRM_THRESHOLD=0.50
# LLM_MAX_CONTEXT_TOKENS=8000
# LLM_TEMPERATURE_CLASSIFY=0.0
# LOG_LEVEL=INFO
# REPORT_LANGUAGE=ru
